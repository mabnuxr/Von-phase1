{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npx vite",
    "build": "npx tsc -b && npx vite build",
    "lint": "npx eslint .",
    "typecheck": "npx tsc --noEmit",
    "format": "npx prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "npx prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "preview": "npx vite preview --host 0.0.0.0 --port 4173",
    "test": "npx vitest run",
    "test:watch": "npx vitest",
    "test:coverage": "npx vitest run --coverage"
  },
  "dependencies": {
    "@crayonai/react-ui": "^0.9.5",
    "@datadog/browser-rum": "^6.27.0",
    "@launchdarkly/observability": "^0.4.9",
    "@launchdarkly/session-replay": "^0.4.9",
    "@phosphor-icons/react": "^2.1.10",
    "@posthog/react": "^1.9.0",
    "@stigg/react-sdk": "^10.0.0",
    "@tanstack/react-query": "^5.90.2",
    "@thesysai/genui-sdk": "^0.7.4",
    "@tiptap/extension-link": "^3.13.0",
    "@tiptap/extension-placeholder": "^3.13.0",
    "@tiptap/extension-table": "^3.13.0",
    "@tiptap/extension-table-cell": "^3.13.0",
    "@tiptap/extension-table-header": "^3.13.0",
    "@tiptap/extension-table-row": "^3.13.0",
    "@tiptap/extension-underline": "^3.13.0",
    "@tiptap/pm": "^3.13.0",
    "@tiptap/react": "^3.13.0",
    "@tiptap/starter-kit": "^3.13.0",
    "@vonlabs/design-components": "*",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.23.24",
    "highcharts": "^12.5.0",
    "highcharts-react-official": "^3.2.3",
    "launchdarkly-react-client-sdk": "^3.9.0",
    "postal-mime": "^2.7.4",
    "posthog-js": "^1.372.9",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0",
    "react-use": "^17.6.0",
    "tiptap-markdown": "^0.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@tanstack/react-query-devtools": "^5.91.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.3",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.44.0",
    "vite": "^7.3.2",
    "vitest": "^3.2.4"
  }
}
