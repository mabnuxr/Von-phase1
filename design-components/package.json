    "format:check": "npx prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "preview": "npx vite preview",
    "storybook": "npx storybook dev -p 6006",
    "build-storybook": "npx storybook build",
    "typecheck": "npx tsc --noEmit",
