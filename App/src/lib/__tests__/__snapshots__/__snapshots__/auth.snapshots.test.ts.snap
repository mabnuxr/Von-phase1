// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Auth Snapshots > should match code verifier storage 1`] = `
{
  "length": 24,
  "stored_verifier": "test-code-verifier-12345",
}
`;

exports[`Auth Snapshots > should match console log output format 1`] = `
{
  "context": "[Auth] snapshot test - access_token:",
  "token": "snapshot-token-123",
}
`;

exports[`Auth Snapshots > should match empty auth state 1`] = `
{
  "access_token": null,
  "code_verifier": null,
  "refresh_token": null,
}
`;

exports[`Auth Snapshots > should match sessionStorage keys after token operations 1`] = `
{
  "keyCount": 3,
  "keys": [
    "access_token",
    "pkce_code_verifier",
    "refresh_token",
  ],
}
`;

exports[`Auth Snapshots > should match token storage structure 1`] = `
{
  "access_token": "sample-access-token",
  "code_verifier": null,
  "refresh_token": "sample-refresh-token",
}
`;
