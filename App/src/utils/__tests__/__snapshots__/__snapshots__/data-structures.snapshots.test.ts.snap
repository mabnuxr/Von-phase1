exports[`Data Structures Snapshots > should match application routes structure 1`] = `
{
  "authRoutes": [
    "/",
    "/callback",
    "/auth/start",
  ],
  "protectedRoutes": [
    "/dashboard",
  ],
  "routes": [
    {
      "component": "RootGate",
      "path": "/",
      "purpose": "Entry point and auth check",
      "redirects": true,
    },
    {
      "component": "Callback",
      "handles": "authorization_code",
      "path": "/callback",
      "purpose": "OAuth callback handler",
    },
    {
      "component": "Dashboard",
      "path": "/dashboard",
      "purpose": "Main application",
      "requiresAuth": true,
    },
    {
      "clearsTokens": true,
      "component": "Logout",
      "path": "/logout",
      "purpose": "Logout confirmation",
    },
    {
      "component": "AuthStart",
      "path": "/auth/start",
      "purpose": "Auto-start auth flow",
      "redirects": true,
    },
  ],
  "totalRoutes": 5,
  "utilityRoutes": [
    "/logout",
  ],
}
`;

