# Revenue OS Frontend - Environment Configuration
# Copy this file to .env and configure for your environment

# ============================================
# APP CONFIGURATION
# ============================================

# API Configuration
# Development: This URL is used by Vite's proxy to forward /api/* requests
# Production: This URL is used directly by the frontend for API calls
# The proxy eliminates CORS issues in development without adding localhost to allowed origins
VITE_API_BASE_URL=http://localhost:4173

# Scalekit Auth Configuration
VITE_SCALEKIT_AUTH_BASE_URL=https://auth.vonlabs.ai
VITE_SCALEKIT_AUTH_AUTHORIZE_PATH=/oauth/authorize
VITE_SCALEKIT_AUTH_TOKEN_PATH=/oauth/token
VITE_SCALEKIT_AUTH_LOGOUT_PATH=/oauth/logout
VITE_SCALEKIT_CLIENT_ID=skc_***
VITE_SCALEKIT_REDIRECT_URI=http://localhost:5176/callback

# ============================================
# DESIGN COMPONENTS / STORYBOOK CONFIGURATION
# ============================================

# Application Environment (development, staging, production)
VITE_APP_ENV=development

# API Configuration for Storybook
VITE_API_TIMEOUT=30000

# Feature Flags
VITE_ENABLE_DEBUG=true
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_REACT_QUERY_DEVTOOLS=false

# Build Configuration
VITE_BUILD_VERSION=dev
VITE_BUILD_TIMESTAMP=

# External Services (configure as needed)
VITE_SENTRY_DSN=
VITE_GA_TRACKING_ID=

# Datadog RUM Configuration
VITE_DD_APPLICATION_ID=
VITE_DD_CLIENT_TOKEN=
VITE_DD_SITE=us5.datadoghq.com

# Pusher Configuration for Real-time Chat
VITE_PUSHER_KEY=
VITE_PUSHER_CLUSTER=

# LaunchDarkly Configuration
VITE_LAUNCHDARKLY_CLIENT_ID=

# PostHog Configuration
VITE_POSTHOG_API_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Knock In-App Guides Configuration
# NON-SECRET / CLIENT-SAFE: these are public values designed to ship in the
# client bundle. The guide runs in public-key-only mode (no userToken, no
# server). Do NOT put a Knock secret key (sk_...) here.
# - Public API key (pk_...) from the Knock dashboard
VITE_KNOCK_PUBLIC_API_KEY=test
# - The in-app guide CHANNEL ID (a UUID from the Knock dashboard — NOT the
#   guide key). The guide key is hardcoded in LaunchModal.tsx.
VITE_KNOCK_GUIDE_CHANNEL_ID=40cda4e3-6003-4a8f-9c77-9875fa8bbfed

# ============================================
# IMPORTANT: DO NOT SET NODE_ENV HERE
# ============================================
# Node.js and npm use NODE_ENV to determine environment
# Setting NODE_ENV=production will skip devDependencies during npm install
# Let the build tools (Vite) handle this automatically
